{
  "name": "@apps/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --watch --env-file=.env src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "lint": "node ../../scripts/noop.mjs",
    "test": "node --env-file=.env ./node_modules/vitest/vitest.mjs run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed:test-data": "tsx --env-file=.env src/seed-test-data.ts",
    "seed:harness": "tsx --env-file=.env src/seed-harness.ts"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@hono/node-server": "^1.14.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@repo/platform-adapters": "workspace:*",
    "@repo/shared-types": "workspace:*",
    "hono": "^4.9.7",
    "jose": "^6.1.3",
    "pg": "^8.16.3",
    "pg-boss": "^10.4.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.0.7"
  }
}
