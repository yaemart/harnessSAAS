model WarrantyRegistration {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @db.Uuid
  consumerId      String         @db.Uuid
  commodityId     String         @db.Uuid
  serialNumber    String
  purchaseDate    DateTime       @db.Date
  purchaseChannel String
  expiryDate      DateTime       @db.Date
  status          String         @default("active")
  activatedAt     DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  consumer        PortalConsumer @relation(fields: [consumerId], references: [id], onDelete: Restrict)
  commodity       Commodity      @relation(fields: [commodityId], references: [id], onDelete: Restrict)

  @@unique([tenantId, serialNumber])
  @@index([tenantId, consumerId])
  @@index([commodityId])
}

model SupportCase {
  id                 String          @id @default(uuid()) @db.Uuid
  tenantId           String          @db.Uuid
  consumerId         String?         @db.Uuid
  commodityId        String          @db.Uuid
  channel            String          @default("portal")
  issueType          String?
  status             String          @default("open")
  priority           String          @default("normal")
  agentConfidence    Float?
  assignedTo         String?
  resolvedAt         DateTime?
  closedAt           DateTime?
  knowledgeWriteback String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  consumer           PortalConsumer? @relation(fields: [consumerId], references: [id], onDelete: SetNull)
  commodity          Commodity       @relation(fields: [commodityId], references: [id], onDelete: Restrict)
  messages           CaseMessage[]
  mediaAnalyses      MediaAnalysis[]

  @@index([tenantId, status])
  @@index([tenantId, status, assignedTo])
  @@index([tenantId, consumerId])
  @@index([commodityId])
}

model CaseMessage {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @db.Uuid
  caseId      String      @db.Uuid
  role        String
  contentType String      @default("text")
  content     String
  metadata    Json?
  createdAt   DateTime    @default(now())
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  case        SupportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@index([tenantId])
}

model MediaAnalysis {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @db.Uuid
  caseId          String      @db.Uuid
  sourceType      String
  analysisResult  Json
  keyFrameUrls    String[]    @default([])
  confidence      Float
  originalFileRef String?
  originalDeleted Boolean     @default(false)
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  case            SupportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([tenantId])
}

model ConsumerFAQ {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @db.Uuid
  brandId     String     @db.Uuid
  commodityId String?    @db.Uuid
  question    String
  answer      String
  category    String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  brand       Brand      @relation(fields: [brandId], references: [id], onDelete: Restrict)
  commodity   Commodity? @relation(fields: [commodityId], references: [id], onDelete: SetNull)

  @@index([tenantId, brandId, commodityId])
}

model ProductFeedback {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @db.Uuid
  consumerId   String         @db.Uuid
  commodityId  String         @db.Uuid
  feedbackType String
  title        String
  detail       String
  priority     String         @default("nice_to_have")
  status       String         @default("submitted")
  agentSummary String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  consumer     PortalConsumer @relation(fields: [consumerId], references: [id], onDelete: Restrict)
  commodity    Commodity      @relation(fields: [commodityId], references: [id], onDelete: Restrict)

  @@index([tenantId, commodityId, feedbackType])
}

model QRScanEvent {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  commodityId String    @db.Uuid
  source      String
  userAgent   String?
  ipCountry   String?
  scannedAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  commodity   Commodity @relation(fields: [commodityId], references: [id], onDelete: Restrict)

  @@index([tenantId, commodityId, source])
  @@index([scannedAt])
}

// ============================================
// Harness — AI Governance Runtime
// ============================================

enum KnowledgeStatus {
  ACTIVE
  DECAYING
  DORMANT
  ARCHIVED
}

enum FeedbackPriorityClass {
  SAFETY
  EXPERIENCE
}

model KnowledgeEntry {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @db.Uuid
  source       String // "writeback" | "faq" | "manual" | "experience"
  category     String // product/issue type (Agent auto-classified + human confirmed)
  content      String
  sourceRef    String? // originating case/FAQ ID
  supersededBy String? @db.Uuid

  status          KnowledgeStatus @default(ACTIVE)
  effectiveWeight Float           @default(1.0)
  decayRate       Float           @default(0.01)
  usageCount      Int             @default(0)
  impactScore     Float           @default(0)
  lastUsedAt      DateTime?
  lastReviewedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId, status, effectiveWeight(sort: Desc)])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, category])
  @@index([tenantId, source])
  @@index([tenantId, source, sourceRef])
  @@index([tenantId, source, createdAt])
  @@index([tenantId, source, lastUsedAt])
}

model FeedbackSignal {
  id            String                @id @default(uuid()) @db.Uuid
  tenantId      String                @db.Uuid
  type          String // "accept" | "reject" | "modify" | "rating" | "resolved" | "system_alert"
  sourceRole    String // "operator" | "tenant_admin" | "consumer" | "system"
  priorityClass FeedbackPriorityClass @default(EXPERIENCE)
  caseId        String?               @db.Uuid
  intentId      String?
  agentAction   String
  reason        String?
  correction    String?
  rating        Int?
  metadata      Json?
  createdAt     DateTime              @default(now())
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, sourceRole, agentAction, intentId])
  @@index([tenantId, type, createdAt])
  @@index([tenantId, type, createdAt, agentAction])
  @@index([tenantId, caseId])
  @@index([tenantId, intentId])
}

model ConfidenceLedger {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @db.Uuid
  agentDomain String  @default("portal") // "portal" | "ads"
  intentId    String?
  caseId      String? @db.Uuid
  agentAction String

  confidenceBefore Float
  confidenceAfter  Float?
  knowledgeUsed    String[] @default([])
  knowledgeWeights Float[]  @default([])
  ruleTriggered    String[] @default([])
  ruleResult       String // "pass" | "soft_warning" | "hard_rejected"
  authorityLevel   String // "auto" | "confirm" | "block"

  executionResult    String // "success" | "failed" | "escalated" | "rejected"
  executionLatencyMs Int?

  feedbackType       String? // "accept" | "reject" | "modify" (async fill)
  feedbackReason     String?
  feedbackSourceRole String?
  feedbackAt         DateTime?

  pipelineVersion     String  @default("1.0")
  tenantMaturityScore Float?
  agentAutonomyLevel  String?

  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  // GIN index on knowledgeUsed: see migration 20260303100000_harness_ledger_gin_and_indexes

  @@index([tenantId, createdAt])
  @@index([tenantId, agentDomain, createdAt])
  @@index([tenantId, agentAction, createdAt])
  @@index([tenantId, caseId])
}

enum AutonomyLevel {
  GUIDED
  ASSISTED
  SUPERVISED
  AUTONOMOUS
}

model TenantMaturity {
  id               String         @id @default(uuid()) @db.Uuid
  tenantId         String         @unique @db.Uuid
  maturityScore    Float          @default(0)
  autonomyLevel    AutonomyLevel  @default(GUIDED)
  autonomyOverride AutonomyLevel?

  knowledgeScore Float @default(0)
  ruleScore      Float @default(0)
  feedbackScore  Float @default(0)
  historyScore   Float @default(0)

  escalationThreshold Float @default(0.9)
  autoExecuteLimit    Float @default(0)

  lastCalculatedAt DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
}

model ExchangeRateConfig {
  id           String   @id @default(cuid())
  provider     String
  apiKey       String
  apiUrl       String?
  baseCurrency String   @default("USD")
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ExchangeRateDailySnapshot {
  id             String   @id @default(cuid())
  date           DateTime @db.Date
  baseCurrency   String
  targetCurrency String
  rate           Float
  source         String
  fetchedAt      DateTime @default(now())

  @@unique([date, baseCurrency, targetCurrency])
  @@index([date])
  @@index([targetCurrency])
  @@index([baseCurrency, targetCurrency])
}

model ExchangeRateMonthlyAvg {
  id             String   @id @default(cuid())
  year           Int
  month          Int
  baseCurrency   String
  targetCurrency String
  avgRate        Float
  minRate        Float
  maxRate        Float
  sampleCount    Int
  calculatedAt   DateTime @default(now())

  @@unique([year, month, baseCurrency, targetCurrency])
  @@index([year, month])
  @@index([targetCurrency])
}
