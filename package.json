{
  "name": "codex-ai-ecom",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @repo/database db:generate",
    "db:migrate": "pnpm --filter @repo/database db:migrate",
    "db:studio": "pnpm --filter @repo/database db:studio",
    "db:seed": "pnpm --filter @repo/database db:seed",
    "week8:validate": "node scripts/week8/run-week8-validation.mjs",
    "week8:soak": "node scripts/week8/run-soak.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "eslint": "^9.21.0",
    "prettier": "^3.5.2",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  }
}
